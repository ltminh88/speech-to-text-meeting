# Supabase
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose

# Centrifugo (shared HMAC secret between token endpoints and the server)
CENTRIFUGO_HMAC_SECRET=change-me-long-random
PUBLIC_CENTRIFUGO_WS_URL=ws://localhost:8000/connection/websocket
CENTRIFUGO_API_URL=http://localhost:8000/api
CENTRIFUGO_API_KEY=change-me-api-key

# App
PUBLIC_APP_URL=http://localhost:5173

# Transcription / summarization (used from Phase 2+)
SONIOX_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Per-session transcript encryption (AES-256-GCM master key, base64 32 bytes)
TRANSCRIPT_MASTER_KEY=
